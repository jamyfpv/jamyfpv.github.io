---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FlightMap from "@/components/FlightMap.astro";
import { getFlightBySlug, getFlightSlugs } from "@/lib/contentful";
import { getFlightSeo } from "@/lib/seo";
import { absoluteUrl, withBase } from "@/lib/site";
import { getYoutubeEmbedUrl } from "@/lib/youtube";

export async function getStaticPaths() {
  const slugs = await getFlightSlugs();
  return slugs.map((slug) => ({
    params: { slug }
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing flight slug.");
}

const flight = await getFlightBySlug(slug);

if (!flight) {
  throw new Error(`Flight not found for slug: ${slug}`);
}

const seo = getFlightSeo(flight);
const embedUrl = getYoutubeEmbedUrl(flight.youtubeVideoId);
type MetadataItem = {
  label: string;
  value: string;
};
type Coordinates = {
  lat: number;
  lon: number;
};

const flightDateLabel = flight.flightDate
  ? new Intl.DateTimeFormat("en", {
      year: "numeric",
      month: "long",
      day: "numeric"
    }).format(new Date(flight.flightDate))
  : null;

const contextualMetadata = [
  flight.shotFor && {
    label: "Produced for",
    value: flight.shotFor
  },
  flight.locationText &&
    !flight.location?.trim() && {
      label: "Location",
      value: flight.locationText
    }
].filter((item): item is MetadataItem => Boolean(item));

function parseCoordinates(location?: string): Coordinates | null {
  if (!location) {
    return null;
  }

  const match = location.match(/(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)/);
  if (!match) {
    return null;
  }

  const lat = Number(match[1]);
  const lon = Number(match[2]);

  if (Number.isNaN(lat) || Number.isNaN(lon)) {
    return null;
  }

  return { lat, lon };
}

const coordinates = parseCoordinates(flight.location);
const hasMap = Boolean(coordinates);
const locationLabel = flight.locationText || flight.location || "";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: flight.seoTitle || flight.title,
  description: flight.seoDescription || flight.shortDescription,
  thumbnailUrl: [flight.thumbnailUrl],
  uploadDate: flight.publishedAt,
  embedUrl,
  contentUrl: flight.youtubeUrl,
  url: absoluteUrl(`/flights/${flight.slug}/`)
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  pathname={seo.pathname}
  image={seo.image}
  type="article"
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <article class="px-6 pb-20 pt-28 md:px-12 md:pb-24">
    <div class="mx-auto grid max-w-6xl gap-8 md:gap-10">
      <header class="grid gap-6 border-b border-border/50 pb-8 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
        <div class="grid gap-4">
          <div class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-primary animate-[pulse-dot_2s_ease-in-out_infinite]"></span>
            <span class="text-xs font-medium uppercase tracking-[0.3em] text-primary">Flight detail</span>
          </div>

          <h1 class="text-4xl font-display font-bold tracking-tight text-foreground md:text-6xl">
            {flight.title}
          </h1>

          {flightDateLabel && (
            <p class="w-fit border-b border-primary/30 pb-1 text-sm font-medium tracking-[0.08em] text-foreground/80 md:text-base">
              {flightDateLabel}
            </p>
          )}

          <p class="max-w-3xl text-base leading-7 text-muted-foreground md:text-lg">
            {flight.shortDescription}
          </p>
        </div>

        <a
          class="inline-flex w-fit items-center gap-2 rounded-md border border-[#db6d17] px-4 py-2 text-xs font-semibold uppercase tracking-[0.15em] text-[#db6d17] no-underline transition-colors duration-300 hover:border-[#a85816] hover:bg-[#a85816] hover:text-white"
          href={withBase("/#showcase")}
        >
          Back to flights
        </a>
      </header>

      {contextualMetadata.length > 0 && (
        <section class="rounded-[20px] border border-border/50 bg-[rgba(24,24,24,0.82)] px-6 py-5 md:px-7">
          <dl class="flex flex-wrap items-center gap-x-6 gap-y-3">
            {contextualMetadata.map((item) => (
              <div class="grid gap-1">
                <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                  {item.label}
                </dt>
                <dd class="m-0 text-sm text-foreground md:text-base">{item.value}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      <section class="grid gap-4">
        <div class="grid gap-3">
          <span class="block h-[0.12rem] w-12 bg-primary" aria-hidden="true"></span>
          <h2 class="text-2xl font-display font-bold text-foreground md:text-3xl">
            Watch the <span class="text-primary">Flight</span>
          </h2>
        </div>

        <div class="overflow-hidden rounded-[20px] border border-border/50 bg-[rgba(24,24,24,0.82)] shadow-[0_24px_80px_rgba(0,0,0,0.35)]">
          <div class="aspect-video bg-black">
            <iframe
              class="h-full w-full"
              src={embedUrl}
              title={flight.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      </section>

      {(flight.body || hasMap) && (
        <section class="grid gap-6">
          {flight.body && (
            <section class="rounded-[20px] border border-border/50 bg-[rgba(24,24,24,0.82)] p-6 md:p-7">
              <div class="mb-5 grid gap-3">
                <span class="block h-[0.12rem] w-12 bg-primary" aria-hidden="true"></span>
                <h2 class="text-2xl font-display font-bold text-foreground md:text-3xl">
                  Behind the <span class="text-primary">Flight</span>
                </h2>
              </div>

              <p class="max-w-3xl whitespace-pre-line text-base leading-8 text-muted-foreground">
                {flight.body}
              </p>
            </section>
          )}

          {coordinates && (
            <section class="overflow-hidden rounded-[20px] border border-border/50 bg-[rgba(24,24,24,0.82)]">
              <div class="border-b border-border/50 px-6 py-5 md:px-7">
                <div class="grid gap-3">
                  <span class="block h-[0.12rem] w-12 bg-primary" aria-hidden="true"></span>
                  <div class="grid gap-1">
                    <h2 class="text-2xl font-display font-bold text-foreground">
                      Flight <span class="text-primary">Location</span>
                    </h2>
                    {locationLabel && <p class="text-sm text-muted-foreground">{locationLabel}</p>}
                  </div>
                </div>
              </div>

              <div class="h-[240px] md:h-[320px]">
                <FlightMap
                  slug={flight.slug}
                  lat={coordinates.lat}
                  lon={coordinates.lon}
                  title={flight.title}
                  locationLabel={locationLabel}
                />
              </div>
            </section>
          )}
        </section>
      )}
    </div>
  </article>
</BaseLayout>

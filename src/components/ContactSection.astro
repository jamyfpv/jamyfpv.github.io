---
import { getContactEmail } from "@/lib/site";

const email = getContactEmail();
---

<section id="contact" class="py-24 px-6 md:px-12 max-w-3xl mx-auto">
  <div class="mb-10 grid justify-items-center gap-3 text-center">
    <div class="h-[0.12rem] w-12 bg-primary"></div>
    <span class="mt-2 text-xs tracking-[0.3em] uppercase text-primary font-medium">
      Contact
    </span>
    <h2 class="text-3xl md:text-4xl font-display font-bold text-foreground">
      Let&apos;s <span class="text-gradient">Fly</span>
    </h2>
    <p class="text-muted-foreground">
      Got a project in mind? Want to collaborate? Drop me a line.
    </p>
  </div>

  <form
    action={`mailto:${email}`}
    method="post"
    enctype="text/plain"
    class="border border-border rounded-xl p-8 space-y-6"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="text-sm font-medium mb-2 block text-foreground" for="name">Name</label>
        <input
          id="name"
          name="name"
          type="text"
          placeholder="Your name"
          class="w-full bg-secondary border border-border rounded-md px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-primary transition-all"
        />
      </div>
      <div>
        <label class="text-sm font-medium mb-2 block text-foreground" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          placeholder="Your@email.com"
          class="w-full bg-secondary border border-border rounded-md px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-primary transition-all"
        />
      </div>
    </div>
    <div>
      <label class="text-sm font-medium mb-2 block text-foreground" for="message">Message</label>
      <textarea
        id="message"
        name="message"
        placeholder="Tell me about your project..."
        rows="5"
        class="w-full bg-secondary border border-border rounded-md px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-primary transition-all resize-none"
      ></textarea>
    </div>
    <button
      type="submit"
      class="w-full py-3 bg-primary text-primary-foreground rounded-md text-xs tracking-[0.15em] uppercase font-semibold hover:brightness-110 transition-all flex items-center justify-center gap-2"
    >
      Send Message
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14.536 21.686a.498.498 0 0 0 .937-.035L21.999 2.5a.499.499 0 0 0-.65-.65L2.199 8.376a.5.5 0 0 0-.035.937l8.005 3.81a2 2 0 0 1 .958.958z"></path>
        <path d="m21.854 2.147-10.94 10.939"></path>
      </svg>
    </button>
  </form>
</section>

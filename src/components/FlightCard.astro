---
import type { Flight } from "@/types/flight";
import { withBase } from "@/lib/site";

interface Props {
  flight: Flight;
}

const { flight } = Astro.props as Props;
const metaPrimary = flight.durationText || "Latest flight";
const metaSecondary = flight.locationText || "Featured location";
const flightHref = withBase(`/flights/${flight.slug}/`);
---

<article class="group">
  <a class="block no-underline" href={flightHref} aria-label={`Open ${flight.title} flight details`}>
    <div class="relative mb-3 overflow-hidden rounded-lg border border-border/50 block">
      <img
        class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
        src={flight.thumbnailUrl}
        alt={flight.thumbnailAlt || `${flight.title} thumbnail`}
        loading="lazy"
        width="1280"
        height="720"
      />
      <span class="absolute inset-0 flex items-center justify-center bg-background/20 transition-colors duration-300 group-hover:bg-background/30">
        <span
          class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-foreground/80 backdrop-blur-sm"
          aria-hidden="true"
        >
          <svg
            class="ml-0.5 h-5 w-5 fill-foreground text-foreground"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
          >
            <polygon points="6 3 20 12 6 21 6 3"></polygon>
          </svg>
        </span>
      </span>
    </div>

    <div class="mb-1.5 flex items-center gap-4">
      <span class="inline-flex items-center gap-1">
        <svg
          class="h-3 w-3 stroke-current text-muted-foreground"
          viewBox="0 0 24 24"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          focusable="false"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span class="text-xs text-muted-foreground">{metaPrimary}</span>
      </span>
      <span class="inline-flex items-center gap-1">
        <svg
          class="h-3 w-3 stroke-current text-muted-foreground"
          viewBox="0 0 24 24"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          focusable="false"
          aria-hidden="true"
        >
          <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a.93.93 0 0 1-1.203 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <span class="text-xs text-muted-foreground">{metaSecondary}</span>
      </span>
    </div>

    <h3 class="font-display font-semibold text-foreground transition-colors duration-300 group-hover:text-primary">
      {flight.title}
    </h3>

    <p class="text-sm text-muted-foreground">{flight.shortDescription}</p>
  </a>
</article>
